# Landing page (Next.js) environment template.
# Copy to .env and fill in every value — all variables are required.

# Base URL of the Hono API server (server-side fetches).
# Required.
API_BASE_URL=

# Fallback branch name when the request host has no branch subdomain
# (bare host, www, or localhost). Must match a branch `name` in the DB.
# Required.
BRANCH_NAME=

# Base URL of the admin dashboard (Vite client). Exposed to the browser;
# used by the preview pages to talk back to the dashboard.
# Required.
NEXT_PUBLIC_DASHBOARD_URL=

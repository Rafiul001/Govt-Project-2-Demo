{
  "name": "govt-project-2-demo",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client,landing -c blue,green,magenta \"bun run dev:server\" \"bun run dev:client\" \"bun run dev:landing\"",
    "dev:server": "bun --watch src/index.ts",
    "dev:client": "cd src/client && bun run dev",
    "dev:landing": "cd src/landing-page && bun run dev --port 3001",
    "install:all": "bun install && cd src/client && bun install && cd ../landing-page && bun install",
    "install:prod": "npm install && cd src/client && npm install && cd ../landing-page && npm install",
    "build": "NODE_ENV=production esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outdir=dist",
    "build:client": "cd src/client && npm run build",
    "build:landing": "cd src/landing-page && npm run build",
    "build:all": "npm run build && npm run build:client && npm run build:landing",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "start:client": "cd src/client && npx vite preview --port 5173",
    "start:landing": "cd src/landing-page && npx next start --port 3001",
    "start:all": "concurrently -n server,client,landing -c blue,green,magenta \"npm run start\" \"npm run start:client\" \"npm run start:landing\""
  },
  "private": true,
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^1.0.0-rc.4",
    "esbuild": "^0.28.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/zod-validator": "^0.8.0",
    "argon2": "^0.44.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}

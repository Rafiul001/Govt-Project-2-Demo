{
  "name": "govt-project-2-demo",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client,landing -c blue,green,magenta \"bun run dev:server\" \"bun run dev:client\" \"bun run dev:landing\"",
    "dev:server": "bun --watch src/index.ts",
    "dev:client": "cd src/client && bun run dev",
    "dev:landing": "cd src/landing-page && bun run dev --port 3001",
    "build": "NODE_ENV=production bun build src/index.ts --outdir dist --target node",
    "start": "node --env-file-if-exists=.env dist/index.js"
  },
  "private": true,
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^1.0.0-rc.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/zod-validator": "^0.8.0",
    "argon2": "^0.44.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}

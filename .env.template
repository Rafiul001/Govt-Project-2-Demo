# Runtime environment: development | production | test
NODE_ENV=development

# Port the HTTP server listens on
PORT=3000

# Pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=debug

# Postgres connection string (local)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/govt_project_2

# JWT secrets — use long, random strings (e.g. `openssl rand -base64 48`)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Token lifetimes with a unit suffix: s, m, h, d (optional; defaults: 15m, 7d)
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d